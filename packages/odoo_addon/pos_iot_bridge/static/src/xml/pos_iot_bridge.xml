<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'receipt-screen') or contains(@class, 'receipt-screen-container')]" position="inside">
            <div class="pos-iot-bridge-panel p-2 border rounded mt-2">
                <div class="fw-bold">Local IoT Bridge</div>
                <div class="small text-muted">
                    <t t-if="iotBridgeStatus.healthy">Connected<t t-if="iotBridgeStatus.printer"> - <t t-esc="iotBridgeStatus.printer"/></t></t>
                    <t t-else="">Disconnected</t>
                </div>
                <div t-if="iotBridgeStatus.lastError" class="text-danger small mt-1">
                    <t t-esc="iotBridgeStatus.lastError.message"/>
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button class="btn btn-secondary" t-on-click="iotBridgeManualPrint">Local reprint</button>
                    <button class="btn btn-outline-secondary" t-on-click="iotBridgeOpenDrawer">Open drawer</button>
                </div>
            </div>
        </xpath>
    </t>
</templates>
