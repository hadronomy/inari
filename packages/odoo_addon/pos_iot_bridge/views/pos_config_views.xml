<odoo>
    <record id="view_pos_config_form_iot_bridge" model="ir.ui.view">
        <field name="name">pos.config.form.iot.bridge</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="IoT Bridge">
                    <group>
                        <group>
                            <field name="iot_bridge_enabled"/>
                            <field name="iot_bridge_agent_url" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_allowed_origin" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_receipt_mode" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_timeout_ms" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_debug" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                        </group>
                        <group>
                            <field name="iot_bridge_auto_print" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_allow_manual_reprint" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_open_cashdrawer" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_default_printer_name" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                            <field name="iot_bridge_kitchen_printer_name" attrs="{'invisible': [('iot_bridge_enabled', '=', False)]}"/>
                        </group>
                    </group>
                    <group string="Optional Hardware">
                        <group>
                            <field name="iot_bridge_scale_enabled"/>
                            <field name="iot_bridge_customer_display_enabled"/>
                            <field name="iot_bridge_scanner_enabled"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
