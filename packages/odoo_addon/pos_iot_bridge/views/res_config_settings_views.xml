<odoo>
    <record id="res_config_settings_view_form_pos_iot_bridge" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.pos.iot.bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <group string="POS IoT Bridge Defaults">
                    <field name="pos_iot_bridge_default_agent_url"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
